<!DOCTYPE html>
<html>
<head><title>Tạo bài mới</title></head>
<body>
    <h1>Tạo bài viết mới</h1>
    <form action="/blogposts/store" method="POST">
        <p>Tiêu đề: <input type="text" name="title" required></p>
        <p>Nội dung: <textarea name="body" rows="5" required></textarea></p>
        <button type="submit">Lưu bài viết</button>
    </form>
    <a href="/">Quay lại</a>
</body>
</html>