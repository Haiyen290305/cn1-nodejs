<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Bài viết</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body style="background-color: #f0f2f5;">
    <div class="container py-5">
        <h1>Bài viết</h1>
        
        <div class="search-section my-5">
            <form action="/" method="GET" class="row g-3 justify-content-center bg-white p-4 rounded-pill shadow-sm">
                <div class="col-md-5">
                    <input type="text" name="search" class="form-control border-0 bg-light rounded-pill px-4" 
                           placeholder="Nhập tên bài viết cần tìm..." value="<%= search || '' %>">
                </div>
                <div class="col-md-3">
                    <select name="category" class="form-select border-0 bg-light rounded-pill">
                        <option value="Tất cả">Tất cả danh mục</option>
                        <option value="Công nghệ" <%= category === 'Công nghệ' ? 'selected' : '' %>>Công nghệ</option>
                        <option value="Đời sống" <%= category === 'Đời sống' ? 'selected' : '' %>>Đời sống</option>
                        <option value="Học tập" <%= category === 'Học tập' ? 'selected' : '' %>>Học tập</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100 rounded-pill fw-bold">Tìm kiếm</button>
                </div>
            </form>
        </div>

        <div style="text-align: center; margin-bottom: 40px;">
            <a href="/blogposts/new" class="btn-new-post"> + Viết bài mới</a>
        </div>

        <div class="row">
            <% if (posts.length > 0) { %>
                <% posts.forEach(post => { %>
                    <div class="col-12 mb-4">
                        <div class="post-card">
                            <span class="category-badge"><%= post.category || 'Công nghệ' %></span>
                            
                            <strong style="font-size: 1.8rem; display: block; margin: 10px 0;">
                                <%= post.title %>
                            </strong>
                            
                            <p style="color: #636e72;">
                                📅 <%= post.createdAt.toLocaleDateString('vi-VN') %> | 👤 Tác giả: Admin
                            </p>
                            
                            <div class="actions">
                                <a href="/blogposts/<%= post._id %>" class="action-link">Xem chi tiết</a>
                                <a href="/blogposts/edit/<%= post._id %>" class="action-link" style="color: #fdcb6e;">Sửa bài</a>
                                
                                <form action="/blogposts/delete/<%= post._id %>" method="POST" style="display:inline;">
                                    <button type="submit" class="btn-delete" onclick="return confirm('Bạn có muốn xóa bài này không?')">
                                        Xóa bài
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="text-center py-5">
                    <h3 class="text-muted">Không tìm thấy bài viết nào phù hợp...</h3>
                    <a href="/" class="btn btn-outline-primary rounded-pill mt-3">Xem tất cả bài viết</a>
                </div>
            <% } %>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>