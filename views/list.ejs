<%- include('layouts/header') %>
<%- include('layouts/navbar') %>

<div class="container mt-5 pt-5">
    <h1>Danh sách tour</h1>

    <% items.forEach(item => { %>
        <div>
            <h3><%= item.name %></h3>
            <p><%= item.description %></p>
